"""Welcome to my Learning progress tracker 0.01"""
import re
import os
import sqlite3

# Initial DB creation using sqlite3. For now, it erases itself every run
if os.path.exists('tracker.db'):
    os.remove('tracker.db')

conn = sqlite3.connect('tracker.db')
cur = conn.cursor()

cur.execute("""
CREATE TABLE IF NOT EXISTS students (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    email TEXT NOT NULL UNIQUE
)
""")
conn.commit()


def run_tracker():
    print("Learning Progress Tracker")
    while True:
        user_input = input().strip()

        if user_input == "exit":
            print("Bye!")
            return

        elif user_input == "add students":
            add_students(cur, conn)

        elif user_input == "back":
            print("Enter 'exit' to exit the program")

        elif not user_input:
            print("No input")

        else:
            print("Unknown command!")


# Student get unique id assigned to the database with name and email as value.
def add_students(cur, conn):
    email_regex = r"^[A-Za-z0-9._-]+@[A-Za-z0-9-]+(\.[A-Za-z0-9-]+)+$"
    name_token_regex = r"^[A-Za-z](?:[A-Za-z]|[-'][A-Za-z])*$"

    print("Enter student credentials or 'back' to return.")
    count = 0

    while True:
        user_input = input().strip()

        if user_input == "back":
            print(f"Total {count} students were added")
            return

        if not user_input:
            print("Incorrect credentials.")
            continue

        parts = user_input.split()
        if len(parts) < 3:
            print("Incorrect credentials.")
            continue

        first_name = parts[0]
        last_name_parts = parts[1:-1]
        email = parts[-1]

        if (re.fullmatch(name_token_regex, first_name) is None or
                len(first_name.replace("-", "").replace("'", "")) < 2):
            print("Incorrect first name.")
            continue

        for token in last_name_parts:
            if (re.fullmatch(name_token_regex, token) is None or
                    len(token.replace("-", "").replace("'", "")) < 2):
                print("Incorrect last name.")
                break
        else:
            if re.fullmatch(email_regex, email) is None:
                print("Incorrect email.")
                continue

            name = " ".join(parts[:-1])

            try:
                cur.execute(
                    "INSERT INTO students (name, email) VALUES (?, ?)",
                    (name, email)
                )
                conn.commit()
                print("valid!")
                count += 1
            except sqlite3.IntegrityError:
                print("This email is already taken.")


run_tracker()
